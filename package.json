{
  "name": "@nbiish/betterbrowsermcp",
  "version": "0.4.0",
  "description": "Better Browser MCP — multi-agent local browser automation with multi-tab support. Drop-in upgrade of @browsermcp/mcp with configurable ports, per-agent WebSocket paths, and no more port-9009 fighting between agents.",
  "author": "Nbiish",
  "homepage": "https://github.com/nbiish/betterbrowsermcp",
  "bugs": {
    "url": "https://github.com/nbiish/betterbrowsermcp/issues"
  },
  "type": "module",
  "bin": {
    "mcp-server-browsermcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --format esm && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsup src/index.ts --format esm --watch ",
    "inspector": "CLIENT_PORT=9001 SERVER_PORT=9002 pnpx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "commander": "^13.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.1",
    "shx": "^0.3.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nbiish/betterbrowsermcp.git"
  }
}
